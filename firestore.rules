rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Hardened Globals
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'phone'); }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isVerified() && getUserData().role == 'admin'; }
    function isRep() { return isVerified() && getUserData().role == 'representative'; }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3
        && data.realName is string && data.realName.size() <= 100
        && data.role in ['employee', 'admin', 'representative']
        && (data.companyId == null || (data.companyId is string && data.companyId.size() <= 100));
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.status == 'pending_payment'
        && data.totalAmount is number && data.totalAmount >= 0
        && data.items is list && data.items.size() > 0
        && data.createdAt == request.time;
    }

    // 3. Match Blocks
    match /users/{userId} {
      allow get: if isVerified();
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) 
                     && incoming().role == 'employee';
      allow update: if isVerified() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'companyId']))
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['role', 'companyId']))
      );
    }

    match /companies/{companyId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /dishes/{dishId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /dailyMenus/{menuId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isRep() || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isRep() || isAdmin());
      
      allow create: if isVerified() && isValidId(orderId) && isValidOrder(incoming());

      allow update: if isVerified() && (
        // Action: Submit Payment
        (isOwner(existing().userId) && existing().status == 'pending_payment' 
         && incoming().status == 'payment_submitted'
         && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentImageUrl', 'note']))
        || 
        // Action: Admin Confirm/Reject
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'shipFee']))
      );
    }

    match /lateOrderRequests/{requestId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow create: if isVerified() && isValidId(requestId) && incoming().userId == request.auth.uid
        && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }
  }
}
