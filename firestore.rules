rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. ADMIN MASTER BY EMAIL (CASE-INSENSITIVE)
    match /{document=**} {
      allow read, write: if request.auth != null && 
        (request.auth.token.email.lower() == 'ha-t@dymvietnam.net');
    }

    // 1. Hardened Globals
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    
    // Kiểm tra admin linh hoạt
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email.lower() == 'ha-t@dymvietnam.net' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }

    function isRep() {
      return isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'representative';
    }
    
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 1
        && data.realName is string && data.realName.size() <= 100
        && data.role in ['employee', 'admin', 'representative']
        && (data.get('companyId', null) == null || (data.companyId is string && data.companyId.size() <= 100));
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.status == 'pending_payment'
        && data.totalAmount is number && data.totalAmount >= 0
        && data.items is list && data.items.size() > 0
        && data.createdAt == request.time;
    }

    // 3. Match Blocks
    match /users/{userId} {
      allow get: if isVerified();
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) 
                     && (incoming().role == 'employee' || request.auth.token.email == 'ha-t@dymvietnam.net');
      allow update: if isVerified() && (
        (isOwner(userId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'companyId', 'username', 'realName']) ||
          (request.auth.token.email == 'ha-t@dymvietnam.net')
        ))
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['role', 'companyId']))
      );
    }

    match /companies/{companyId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /dishes/{dishId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /combos/{comboId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /dailyMenus/{menuId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    function isBeforeDeadline() {
      // 10:30 AM in GMT+7 (assuming server time is handled properly)
      // For simplicity, we check if current time hour is < 10 or (hour == 10 and min <= 30)
      // request.time.getHours() depends on timezone, we'll use a safer approach in production
      return true; // Will be refined with timestamp logic
    }

    match /orders/{orderId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidId(orderId) && isValidOrder(incoming())
                     && (isBeforeDeadline() || isAdmin()); // Admin can override deadline

      allow update: if isVerified() && (
        (isOwner(existing().userId) && existing().status == 'pending' 
         && incoming().status == 'submitted' && incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'billImageUrl']))
        || (isAdmin())
      );
    }

    match /lateOrderRequests/{requestId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow create: if isVerified() && isValidId(requestId) && incoming().userId == request.auth.uid
        && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }
  }
}
