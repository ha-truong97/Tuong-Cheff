{
  "entities": {
    "users": {
      "title": "Người dùng",
      "description": "Thông tin tài khoản đăng nhập và phân quyền",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Tên đăng nhập (Real Name - Unique)" },
        "password": { "type": "string", "description": "Hashed password" },
        "realName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin", "representative"] },
        "companyId": { "type": "string" },
        "mustChangePassword": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "password", "role"]
    },
    "companies": {
      "title": "Công ty",
      "description": "Danh sách các văn phòng đặt hàng",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "memberCount": { "type": "number" }
      }
    },
    "dishes": {
      "title": "Món ăn",
      "description": "Danh mục món ăn hàng ngày",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "basePrice": { "type": "number", "description": "Giá mặc định (thường 36000)" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["main", "addon"] }
      }
    },
    "dailyMenus": {
      "title": "Thực đơn ngày",
      "description": "Gán món ăn vào ngày cụ thể và điều chỉnh giá",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "dishIds": { "type": "array" },
        "customPrices": { "type": "object", "description": "Lưu {dishId: price} nếu khác mặc định" },
        "status": { "type": "string", "enum": ["draft", "published"] }
      }
    },
    "orders": {
      "title": "Đơn hàng",
      "description": "Thông tin chi tiết đơn đặt cơm",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "companyId": { "type": "string" },
        "items": { "type": "array", "description": "Mảng các món (OrderItem)" },
        "totalAmount": { "type": "number" },
        "totalQuantity": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "submitted", "confirmed", "rejected"] },
        "billImageUrl": { "type": "string" },
        "shipFee": { "type": "number" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "users", "description": "Danh sách người dùng" },
    "companies": { "schema": "companies", "description": "Danh sách công ty" },
    "dishes": { "schema": "dishes", "description": "Kho món ăn" },
    "dailyMenus": { "schema": "dailyMenus", "description": "Lịch thực đơn hàng ngày" },
    "orders": { "schema": "orders", "description": "Quản lý đơn hàng" }
  }
}
